# ─────────────────────────────────────────────────────────────────
# BASE — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# ─────────────────────────────────────────────────────────────────

# Chiave segreta Django (cambia in produzione!)
SECRET_KEY=django-insecure-change-me-in-production

# Debug (True in sviluppo, False in produzione)
DEBUG=True

# Host consentiti (virgola-separati, es: miodominio.com,www.miodominio.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# URL del sito (usato per link assoluti nelle email)
SITE_URL=http://127.0.0.1:8000

# ─── DATABASE ────────────────────────────────────────────────────
# Lascia vuoto per SQLite (sviluppo)
# In produzione usa: postgres://user:password@host:5432/dbname
DATABASE_URL=

# ─── EMAIL ───────────────────────────────────────────────────────
# Backend email (console = solo log, smtp = invio reale)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@base.local
